<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="http://d2os.com/bpmn"
             id="d2os-initiation-v2-definitions">

  <!--
    Initiation workflow v2 (T016/T020, Phase 2). The full §7 canonical persona suite. Activity ids ARE
    persona keys (T008), so PersonaStepDelegate resolves each sequential step by id. Every step is
    async so it runs on the persisted job executor (NFR-4).

    PARALLEL analysis block (US2, research R1 with a deviation): the four analysis specialists run
    concurrently inside a SINGLE service task, `analysis-specialists`, which fans them out across a
    bounded application thread pool (ParallelSpecialistsDelegate). We deviate from a BPMN parallel
    gateway because embedded Flowable serialized four async branch jobs under process-instance
    optimistic-lock contention, defeating real parallelism; app-level fan-out gives deterministic
    wall-clock overlap with no engine join contention, while per-branch provenance still lands in the
    domain tables (branch-tagged persona_invocation/operation_execution). The delegate joins on all
    four (FR-004) and sets `validated = all four passed`; a partial failure routes to the escalation
    wait receiveTask (FR-005) with every specialist's output already persisted (siblings retained),
    released by EscalationBridge once no branch remains escalated.
  -->
  <process id="initiation-v2" name="Initiation Case (full suite)" isExecutable="true">

    <startEvent id="start"/>
    <sequenceFlow id="s0" sourceRef="start" targetRef="intake-analyst"/>

    <serviceTask id="intake-analyst" name="Intake Analyst"
                 flowable:async="true" flowable:delegateExpression="${personaStepDelegate}"/>
    <sequenceFlow id="s1" sourceRef="intake-analyst" targetRef="business-analyst"/>

    <serviceTask id="business-analyst" name="Business Analyst"
                 flowable:async="true" flowable:delegateExpression="${personaStepDelegate}"/>
    <sequenceFlow id="s2" sourceRef="business-analyst" targetRef="product-functional-analyst"/>

    <serviceTask id="product-functional-analyst" name="Product/Functional Analyst"
                 flowable:async="true" flowable:delegateExpression="${personaStepDelegate}"/>
    <sequenceFlow id="s3" sourceRef="product-functional-analyst" targetRef="solution-architect"/>

    <serviceTask id="solution-architect" name="Solution Architect"
                 flowable:async="true" flowable:delegateExpression="${personaStepDelegate}"/>
    <sequenceFlow id="s4" sourceRef="solution-architect" targetRef="api-designer"/>

    <serviceTask id="api-designer" name="API Designer"
                 flowable:async="true" flowable:delegateExpression="${personaStepDelegate}"/>
    <sequenceFlow id="s5" sourceRef="api-designer" targetRef="analysis-specialists"/>

    <!-- ===== Parallel analysis-specialist block (US2): four specialists fan out concurrently ===== -->
    <serviceTask id="analysis-specialists" name="Analysis Specialists (Security ∥ UX ∥ Data ∥ Infra)"
                 flowable:async="true" flowable:delegateExpression="${parallelSpecialistsDelegate}"/>
    <sequenceFlow id="s6" sourceRef="analysis-specialists" targetRef="gw-specialists"/>

    <exclusiveGateway id="gw-specialists" default="w-spec-in"/>
    <sequenceFlow id="v-spec" sourceRef="gw-specialists" targetRef="consistency-check">
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${validated}]]></conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="w-spec-in" sourceRef="gw-specialists" targetRef="specialists-wait"/>
    <receiveTask id="specialists-wait" name="Await specialist escalation resolution"/>
    <sequenceFlow id="w-spec-out" sourceRef="specialists-wait" targetRef="consistency-check"/>
    <!-- ===== end parallel block ===== -->

    <!-- ===== Consistency-Check (US3): deterministic contradictions block; semantic findings escalate ===== -->
    <serviceTask id="consistency-check" name="Consistency Check"
                 flowable:async="true" flowable:delegateExpression="${consistencyCheckDelegate}"/>
    <sequenceFlow id="s6a" sourceRef="consistency-check" targetRef="gw-consistency"/>
    <exclusiveGateway id="gw-consistency" default="w-cons-in"/>
    <sequenceFlow id="v-cons" sourceRef="gw-consistency" targetRef="qa-test-strategist">
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${consistencyClean}]]></conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="w-cons-in" sourceRef="gw-consistency" targetRef="consistency-wait"/>
    <receiveTask id="consistency-wait" name="Await consistency resolution"/>
    <sequenceFlow id="w-cons-out" sourceRef="consistency-wait" targetRef="qa-test-strategist"/>
    <!-- ===== end consistency-check ===== -->

    <serviceTask id="qa-test-strategist" name="QA/Test Strategist"
                 flowable:async="true" flowable:delegateExpression="${personaStepDelegate}"/>
    <sequenceFlow id="s7" sourceRef="qa-test-strategist" targetRef="risk-governance-officer"/>

    <serviceTask id="risk-governance-officer" name="Risk &amp; Governance Officer"
                 flowable:async="true" flowable:delegateExpression="${personaStepDelegate}"/>
    <sequenceFlow id="s8" sourceRef="risk-governance-officer" targetRef="delivery-planner"/>

    <serviceTask id="delivery-planner" name="Delivery Planner"
                 flowable:async="true" flowable:delegateExpression="${personaStepDelegate}"/>
    <sequenceFlow id="s9" sourceRef="delivery-planner" targetRef="technical-writer"/>

    <serviceTask id="technical-writer" name="Technical Writer"
                 flowable:async="true" flowable:delegateExpression="${personaStepDelegate}"/>
    <sequenceFlow id="s10" sourceRef="technical-writer" targetRef="assemble-package"/>

    <serviceTask id="assemble-package" name="Assemble Package"
                 flowable:async="true" flowable:delegateExpression="${assemblePackageDelegate}"/>
    <sequenceFlow id="s11" sourceRef="assemble-package" targetRef="end"/>

    <endEvent id="end"/>
  </process>
</definitions>
