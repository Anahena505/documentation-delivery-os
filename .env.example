# Local development environment for D2OS. Copy to `.env` and set real values:
#   cp .env.example .env
# `.env` is gitignored — never commit real credentials. docker-compose reads it automatically;
# for `./gradlew :app:bootRun`, export these into the shell (or use a tool like direnv).
#
# These are LOCAL DEV credentials for throwaway containers. Production provisions the DB roles and
# object-store keys via infra-as-code / a secrets manager — do not reuse these values anywhere real.

# --- PostgreSQL ---
# Schema-owning role (runs Flyway migrations).
D2OS_DB_OWNER_USER=d2os_owner
D2OS_DB_OWNER_PASSWORD=change-me-owner
# Least-privilege runtime role the app connects as (created by V8__app_role.sql). Its password is
# injected into the migration via the Flyway placeholder, so this one value drives both.
D2OS_DB_APP_USER=d2os_app
D2OS_DB_APP_PASSWORD=change-me-app

# --- Object storage (MinIO / S3) ---
D2OS_STORAGE_ACCESS_KEY=d2os
D2OS_STORAGE_SECRET_KEY=change-me-minio

# --- AI Gateway (optional for local runs; required to call a real provider) ---
D2OS_AI_PROVIDER=anthropic
D2OS_AI_MODEL=claude-sonnet-5
# D2OS_AI_API_KEY=sk-ant-...
